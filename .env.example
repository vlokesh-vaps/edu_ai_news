# Environment Variables Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive information

# Groq API Configuration
# Get your free API key from: https://console.groq.com
# Rate limits: Free tier is generous (500+ requests/day)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Logging Configuration
# Options: DEBUG (verbose), INFO (normal), WARNING (warnings only), ERROR (errors only), CRITICAL (critical only)
# Use DEBUG during development, INFO in production
LOG_LEVEL=INFO

# Application Configuration (optional, edit in config.py if needed)
# APP_TITLE=edu-news-ticker
# APP_VERSION=1.0.0

